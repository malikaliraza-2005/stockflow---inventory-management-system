# ims-server environment inventory (SRS §18.4 · NFR-28 · DEP §7)
# Names + purpose ONLY — real values live in local .env (dev) or the platform
# secret manager (staging/prod, SEC-10). Boot aborts naming any missing or
# invalid variable (src/config/env.ts).

# --- Runtime ---
NODE_ENV=                       # development | test | staging | production
PORT=                           # bind port (default 3000)

# --- Database ---
MONGODB_URI=                    # Atlas SRV string, least-privilege user (SEC-11)

# --- Auth secrets (SEC-01: >= 32 chars / 256-bit, per-environment, distinct) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=               # e.g. 15m (default 15m)
REFRESH_TOKEN_TTL=              # e.g. 7d (default 7d)

# --- HTTP ---
CORS_ORIGIN=                    # exact frontend origin for this environment (DEP §8)
TRUST_PROXY_HOPS=               # exact platform proxy hop count, verified per env (ARB-01/R-4); default 0

# --- Cloudinary (SEC-08) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Seed bootstrap (FR-USER-06) — rotate after first login ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Rate limiting (SEC-04) — defaults: global 300 / 15 min, strict 10 / 15 min ---
RATE_LIMIT_GLOBAL_MAX=
RATE_LIMIT_GLOBAL_WINDOW_MS=
RATE_LIMIT_STRICT_MAX=
RATE_LIMIT_STRICT_WINDOW_MS=

# --- Observability ---
LOG_LEVEL=                      # fatal | error | warn | info | debug | trace (default info)
SENTRY_DSN=                     # error-tracker DSN (NFR-23); optional
