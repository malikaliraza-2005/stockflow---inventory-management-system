{
  "name": "ims-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e --passWithNoTests"
  },
  "dependencies": {
    "express": "^4.22.2",
    "mongoose": "^8.16.0",
    "pino": "^10.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.15.0",
    "@types/supertest": "^7.2.1",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "mongodb-memory-server": "^10.1.0",
    "prettier": "^3.6.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0",
    "yaml": "^2.9.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "mongodb-memory-server@10.4.3": true
  }
}
